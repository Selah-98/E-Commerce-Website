@page
@model JKCrafts.Pages.Products.CreateModel
@{
}

<h2>New Products</h2>

@if (Model.errorMessage.Length > 0)
{
    <div class='alert-warning alert-dismissible fade show' role='alert'>
        <strong>@Model.errorMessage</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
    </div>
}

<form method="post">


    <div class="row mb-3">
        <label class="col-sm-3 col-form-label">Name</label>
        <div>
            <input type="text" class="form-control" name="Name" value="@Model.customerinfo.Name">
        </div>

    </div>
    <div class="row mb-3">
        <label class="col-sm-3 col-form-label">Price</label>
        <div>
            <input type="text" class="form-control" name="Price" value="@Model.customerinfo.Price">
        </div>

    </div>
    
    @if (Model.successMessage.Length > 0)
    {
        <div class="row mb-3">
            <div class="col-sm-9">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong>@Model.successMessage</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
                </div>
            </div>
        </div>
    }
    <div class="row mb-3">
        <div class="offset-sm-3 col-sm-3 d-grid">
            <a class="btn btn-outline-primary" href="/Products/Create" role="button">Submit</a>

        </div>
        <div class="col-sm-3 d-grid">
            <a class="btn btn-outline-primary" href="/Products" role="button">Cancel</a>
        </div>
    </div>

</form>